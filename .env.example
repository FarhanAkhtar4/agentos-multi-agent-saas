# AgentOS v2 — Environment Configuration
# Copy this file to .env.local and fill in your values.
#
# NEVER commit this file to version control!

# ── Next.js ──────────────────────────────────────────────────────
NODE_ENV=development
DATABASE_URL=file:./db/agentos.db

# ── LLM (via z-ai-web-dev-sdk) ───────────────────────────────────
# These are configured through the z-ai-web-dev-sdk
LLM_MODEL=deepseek-chat

# ── FastAPI Orchestrator ────────────────────────────────────────
ORCHESTRATOR_URL=http://localhost:3100
ORCHESTRATOR_PORT=3100

# ── Agent Pipeline ──────────────────────────────────────────────
AGENT_PIPELINE=ceo,developer,qa
MAX_PIPELINE_ERRORS=3

# ── Human-in-the-Loop ───────────────────────────────────────────
HITL_FINANCIAL_THRESHOLD=50.0

# ── Memory ───────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=agentos_memory
MEMORY_MAX_RESULTS=10
SESSION_TTL=86400

# ── External Services (Production) ──────────────────────────────
# PostgreSQL (for LangGraph checkpoints)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=agentos
POSTGRES_PASSWORD=agentos_dev_2024
POSTGRES_DB=agentos

# Redis (session caching)
REDIS_URL=redis://localhost:6379/0

# ── Authentication (NextAuth.js) ────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Observability ────────────────────────────────────────────────
# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=agentos-frontend

# Langfuse (LLM evaluation)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
