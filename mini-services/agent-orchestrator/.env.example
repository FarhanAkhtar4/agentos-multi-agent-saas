# AgentOS v2 — Environment Configuration
# Copy this file to .env and fill in your values.

# ── Service ────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=3100

# ── LLM (uses z-ai-web-dev-sdk via Next.js API) ────────────────────
NEXTJS_URL=http://localhost:3000
LLM_MODEL=deepseek-chat
LLM_TIMEOUT=120
LLM_MAX_RETRIES=3

# ── Agent Pipeline ─────────────────────────────────────────────────
# Comma-separated list of agent roles in execution order
AGENT_PIPELINE=ceo,developer,qa

# ── Human-in-the-Loop ─────────────────────────────────────────────
# Dollar threshold for requiring human approval
HITL_FINANCIAL_THRESHOLD=50.0

# ── Error Handling ────────────────────────────────────────────────
MAX_PIPELINE_ERRORS=3

# ── Memory ─────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=agentos_memory
MEMORY_MAX_RESULTS=10
SESSION_TTL=86400

# ── CORS ───────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
