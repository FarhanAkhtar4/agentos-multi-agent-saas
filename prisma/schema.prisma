// AgentOS - Multi-Agent SaaS Platform Schema
// =============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============ CORE MODELS ============

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("active") // active, completed, archived
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks  Task[]
  agents AgentRun[]
}

model Task {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  description String
  status      String   @default("pending") // pending, running, completed, failed, cancelled
  priority    String   @default("medium")  // low, medium, high, critical
  input       String?                      // Original user input
  output      String?                      // Final output/summary
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agentRuns  AgentRun[]
}

model AgentRun {
  id          String   @id @default(cuid())
  taskId      String
  projectId   String
  agentType   String                      // ceo, pm, developer, qa, devops, hr
  agentName   String
  status      String   @default("pending") // pending, running, completed, failed
  input       String?                      // Input to this agent
  output      String?                      // Output from this agent
  error       String?
  duration    Int?                         // Duration in ms
  order       Int                          // Execution order in pipeline
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  logs   AgentLog[]
}

model AgentLog {
  id        String   @id @default(cuid())
  runId     String
  level     String   @default("info") // debug, info, warn, error
  message   String
  metadata  String?                     // JSON string for additional data
  createdAt DateTime @default(now())

  agentRun AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String                      // user, assistant, system, agent
  agentType String?                     // Which agent sent this
  content   String
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model ChatSession {
  id        String   @id @default(cuid())
  title     String   @default("New Session")
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ChatMessage[]
}
